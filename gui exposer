local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Create GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GUI_Explorer"
screenGui.Parent = playerGui

-- Main frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 300, 0, 400)
frame.Position = UDim2.new(0, 50, 0, 50)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.BackgroundColor3 = Color3.fromRGB(20,20,20)
title.Text = "GUI Explorer"
title.TextColor3 = Color3.new(1,1,1)
title.Parent = frame

-- Scroll area
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,0,1,-30)
scroll.Position = UDim2.new(0,0,0,30)
scroll.BackgroundColor3 = Color3.fromRGB(40,40,40)
scroll.ScrollBarThickness = 6
scroll.Parent = frame

-- Layout
local layout = Instance.new("UIListLayout")
layout.Parent = scroll
layout.SortOrder = Enum.SortOrder.LayoutOrder

-- AUTO UPDATE SCROLL SIZE
layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end)

-- Function to add GUI items
local function addGui(gui)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1,-5,0,25)
	button.BackgroundColor3 = Color3.fromRGB(60,60,60)
	button.TextColor3 = Color3.new(1,1,1)
	button.Text = gui.Name
	button.Parent = scroll

	button.MouseButton1Click:Connect(function()
		print("Selected:", gui:GetFullName())
	end)
end

-- Scan existing GUIs
for _,gui in pairs(playerGui:GetDescendants()) do
	if gui:IsA("GuiObject") then
		addGui(gui)
	end
end

-- Detect new GUIs
playerGui.DescendantAdded:Connect(function(gui)
	if gui:IsA("GuiObject") then
		addGui(gui)
	end
end)
